{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=paynowstore.db"
  },
  "Jwt": {
    "Issuer": "PayNowStore",
    "Audience": "PayNowStoreClient",
    "Key": "CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_KEY"
  },
  "Paynow": {
    "IntegrationId": "YOUR_PAYNOW_INTEGRATION_ID",
    "IntegrationKey": "YOUR_PAYNOW_INTEGRATION_KEY",
    "BaseUrl": "https://www.paynow.co.zw",
    "ReturnUrl": "http://localhost:5173/payment/return",
    "ResultUrl": "https://your-api-host/api/payments/callback"
  },
  "AllowedHosts": "*"
}
